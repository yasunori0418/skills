{
  "description": "cchook から移植した skill 非依存の個人運用 guard 群: AskUserQuestion のセッション単位無効化 (#aq-off/#aq-on)、AskUserQuestion 発火時のデスクトップ通知、github.com への WebFetch の gh 誘導、sudo の禁止、Stop 時のデスクトップ通知。git rebase/reset の強制 (git-guard) は git-skills プラグインへ分離した。",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/askuserquestion-guard/main.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/askuserquestion-notify/main.sh"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/webfetch-github-guard/main.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/sudo-guard/main.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/askuserquestion-toggle/main.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/notify-stop/main.sh"
          }
        ]
      }
    ]
  }
}
